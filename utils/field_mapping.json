{
  "_notes": [
    "所有 Excel JSON 顶层都是 { DataList: [...] }",
    "日文文本字段为 TextJp / MessageJP / LocalizeJP / NameJp / FullNameJp 等，命名不统一，按表区分",
    "Korean script directives 混在 ScriptKr 中；TextJp 本身是纯净日文（无 directive 前缀）",
    "CharacterId 与 Excel 各表的 Id 对齐（10000=Aru, 10004=Hina 等）",
    "Korean 角色名通过 ScenarioCharacterNameExcelTable.NameKR -> NameJP 查 Japanese name"
  ],

  "ScenarioScript": {
    "_files": [
      "ScenarioScriptMain1ExcelTable.json", "ScenarioScriptMain2ExcelTable.json",
      "ScenarioScriptMain3ExcelTable.json", "ScenarioScriptMain4ExcelTable.json",
      "ScenarioScriptMain5ExcelTable.json",
      "ScenarioScriptGroup1ExcelTable.json", "ScenarioScriptGroup2ExcelTable.json", "ScenarioScriptGroup3ExcelTable.json",
      "ScenarioScriptFavor1ExcelTable.json", "ScenarioScriptFavor2ExcelTable.json", "ScenarioScriptFavor3ExcelTable.json",
      "ScenarioScriptEvent1ExcelTable.json", "ScenarioScriptEvent2ExcelTable.json", "ScenarioScriptEvent3ExcelTable.json", "ScenarioScriptEvent4ExcelTable.json",
      "ScenarioScriptField1ExcelTable.json",
      "ScenarioScriptContentExcelTable.json"
    ],
    "group_id": "GroupId",
    "selection_group": "SelectionGroup",
    "script_kr": "ScriptKr",
    "text_jp": "TextJp",
    "voice_jp": "VoiceJp",
    "bg_name_hash": "BGName",
    "bgm_id": "BGMId",
    "sound": "Sound",
    "_script_kr_format": {
      "directive_wait": "#wait;NNN  - pause in ms",
      "directive_place": "#place;<name>  - location label (TextJp has Jp label)",
      "directive_title": "#title;<text>  - story title banner",
      "directive_hidemenu": "#hidemenu / #all;hide",
      "narration_stm": "#stm;[x,y];serial;speed;<text>  - scroll narration",
      "narration_st": "#st;[x,y];serial;speed;<text>  - static narration",
      "narration_na": "#na;<speaker_kr>;<text>  - narration; speaker可 ??? 或任意 KR 名",
      "dialogue": "<pos>;<speaker_kr>;<emotion>[\\n#<pos>;<anim>[\\n#na;<text>]]  - character line, speaker in field[1]",
      "selection": "[s] <text>  - player choice option (also in TextJp as [s] ...)",
      "embedded_break": "#n inside text = hard newline"
    },
    "_selection_group_semantics": "SelectionGroup=0 = main flow (including [s] choice offers); SelectionGroup>0 = branch executed after player picks that option (rows for unselected branches also present, replayable)"
  },

  "ScenarioCharacterName": {
    "_file": "ScenarioCharacterNameExcelTable.json",
    "character_hash": "CharacterName",
    "name_kr": "NameKR",
    "nickname_kr": "NicknameKR",
    "name_jp": "NameJP",
    "nickname_jp": "NicknameJP",
    "shape": "Shape",
    "spine_prefab": "SpinePrefabName",
    "portrait": "SmallPortrait",
    "_note": "NameKR 可能重复（同角色不同 variant）—— 按 Kr->Jp 取首个足够；nickname 用于 club/context 区分"
  },

  "AcademyMessanger": {
