    "feedback_time_ms": "FeedbackTimeMillisec",
    "message_type": "MessageType",
    "image_path": "ImagePath",
    "message_kr": "MessageKR",
    "message_jp": "MessageJP",
    "_message_type_values": ["Text", "Image", "Sticker", "Reply"],
    "_condition_values": ["FavorRankUp", "None", "Choice"]
  },

